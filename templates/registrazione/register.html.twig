{% extends 'base.html.twig' %}
{% form_theme registrationForm 'bootstrap_5_layout.html.twig' %}
{% trans_default_domain 'app' %}

{% block title %}Registrazione Utente{% endblock %}

{% block body %}

    {% import "macros/macro_navbar.html.twig" as form %}
    {{form.navbar(activeNuovoUtente: "active")}}
        
    <div class="d-flex p-2 justify-content-center">
        <div class="d-flex p-2 align-items-center flex-column">

            <h1>Registrazione Nuovo Utente</h1>

            {{ form_errors(registrationForm) }}

            {{ form_start(registrationForm) }}
                <div class="d-flex p-2 align-items-center flex-column">
                    {{ form_row(registrationForm.nomeUtente)}}
                    {{ form_row(registrationForm.email) }}
                    {{ form_row(registrationForm.plainPassword) }}
                    {{ form_row(registrationForm.roles) }}
                    <button type="submit" class="btn btn-primary bg-gradient">Conferma</button>
                </div>
        
            {{ form_end(registrationForm) }}
        </div>
    </div>
{% endblock %}
