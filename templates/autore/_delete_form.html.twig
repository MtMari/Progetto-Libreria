<form method="post" action="{{ path('app_autore_delete', {'id': autore.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ autore.id) }}">
    <button class="btn btn-danger mb-2 ms-2"><i class="bi bi-trash3-fill me-1"></i>Elimina</button>
</form>
