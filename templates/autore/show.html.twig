{% extends 'base.html.twig' %}

{% block title %}Autore{% endblock %}

{% block body %}

    {% import "macros/macro_navbar.html.twig" as form %}
    {{form.navbar}}

    <h1 class="ms-2">Autore</h1>
    {% if app.user %}
        <div class="d-flex p-1">
            <a href="{{ path('app_autore_edit', {'id': autore.id}) }}" class="btn btn-primary bg-gradient me-2 mb-2"><i class="bi bi-pencil-square me-1" style="font-size: 1.1rem;"></i>Modifica</a>
            {{ include('autore/_delete_form.html.twig') }}
        </div>
    {% endif %}
    <div class="w-25">
        <table class="table">
            <tbody>
                <tr>
                    {# <th class="border-end border-bottom border-dark table-primary">Id</th>
                    <td class="table-light">{{ autore.id }}</td> #}
                </tr>
                <tr>
                    <th class="border-end border-bottom border-dark table-primary">Nome Autore</th>
                    <td>{{ autore.nomeAutore }}</td>
                </tr>
                <tr>
                    <th class="border-end border-bottom border-dark table-primary">Cognome Autore</th>
                    <td class="table-light">{{ autore.cognomeAutore }}</td>
                </tr>
                <tr>
                    <th class="border-end border-bottom border-dark table-primary">Data Nascita</th>
                    <td>{{ autore.dataNascita ? autore.dataNascita|date('Y-m-d') : '' }}</td>
                </tr>
                {% if app.user %}                
                    <tr>
                        <th class="border-end border-dark table-primary">Disponibile</th>
                        <td class="table-light">{{ autore.disponibilita ? 'Sì' : 'No' }}</td>
                    </tr>
                    <tr>
                        <th class="border-end border-top border-dark table-primary">Punteggio</th>
                        <td>{{ autore.qualitaScrittura ? autore.qualitaScrittura : 'Dato non disponibile' }}</td>
                    </tr>
                {% endif %}
            </tbody>
        </table>
    </div>

{% endblock %}
