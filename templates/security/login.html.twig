{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}

    {% import "macros/macro_navbar.html.twig" as form %}
    {{form.navbar(activeLogIn: 'active')}}
    
    <div class="d-flex p-2 justify-content-center">
        <form method="post">
            <div class="d-flex p-2 align-items-center flex-column">

                {% if error %}
                    <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                <h1 class="mb-3 font-weight-normal">Log in</h1>

                {% if app.user %}
                    <div class="my-3">
                        <i class="bi bi-exclamation-lg text-danger"></i>
                        <span class="small-text">Login effettuato come: {{ app.user.userIdentifier }}.</span>
                        <a href="{{ path('app_logout') }}">Logout</a>
                    </div>
                {% endif %}

                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">
                <div>
                    <label for="username">Nome Utente</label>
                    <input type="text" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="username" required autofocus>
                </div>
                <div>
                    <label for="password">Password</label>
                    <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required>
                </div>
                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                <button class="btn btn-primary bg-gradient mt-3" type="submit">
                    Log in
                </button>
            </div>
        </form>
    </div>

{% endblock %}
