{% macro navbar(activeAutori, activeLibri, activeNuovoUtente) %}
    <nav class="navbar navbar-expand-lg bg-primary bg-gradient mb-3 fs-5 p-3" data-bs-theme="dark">
        <div class="container-fluid">
            <ul class="navbar-nav">
                <li class="nav-item ms-1 me-3">
                    <a>Home</a>
                </li>
                <li class="nav-item mx-3">
                    <a href="{{ path('app_autore_index') }}" class="nav-link {{ activeAutori }}">Index Autori</a>
                </li>
                <li class="nav-item mx-3">
                    <a href="{{ path('app_libro_index') }}" class="nav-link {{ activeLibri }}">Index Libri</a>
                </li>
                {% if is_granted('ROLE_ADMIN')%}
                    <li class="nav-item in-linea mx-3">
                        <a href="{{ path('app_registrazione') }}" class="nav-link {{ activeNuovoUtente }}">Nuovo Utente</a>
                    </li>
                {% endif %}
            </ul>
            {% if app.user %}
                <div class="border border-light border-2 rounded-3 fs-6 me-3">
                    <span class="text-light mx-3">{{ app.user.userIdentifier }}</span>
                    <a href="{{ path('app_logout') }}" class= "btn btn-light p-2">Logout</a>
                </div>
            {% else %}
                <div class="border border-light border-2 rounded-3 me-3">
                    <a href="{{ path('app_login') }}" class="btn-light btn btn-sm bg-gradient fs-6 px-3">Log in</a>
                </div>
            {% endif %}
        </div>
    </nav>
        {% if is_granted('IS_IMPERSONATOR') %}
            <a class="d-flex p-2 justify-content-center w-100" href="{{ impersonation_exit_path(path('app_libro_index')) }}">Exit impersonation</a>
        {% endif %}
{% endmacro navbar %}